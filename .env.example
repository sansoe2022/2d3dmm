# Backend API URL for Telegram bot integration
# Set this to the URL where your bot/server.js is running
# Leave empty to disable API sync (app works offline with localStorage only)
VITE_API_URL=http://localhost:4000

# Example for production VPS:
# VITE_API_URL=http://your-vps-ip:4000
# VITE_API_URL=https://api.yourdomain.com
